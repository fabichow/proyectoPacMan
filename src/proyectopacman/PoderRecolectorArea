package proyectopacman;

public class PoderRecolectorArea {

//Atributos
String tipo;
int rango;

//Constructor
public PoderRecolectorArea(int rango) {
    this.tipo = "RecolectorArea";
    this.rango = rango;
}

// Metodos
public void activar(Jugador j, Punto[] puntos) {
    for (int i = 0; i < puntos.length; i++) {
        if (!puntos[i].fueRecolectado()) {
            int distFila = Math.abs(j.fila - puntos[i].fila);
            int distCol = Math.abs(j.columna - puntos[i].columna);

            if (distFila <= rango && distCol <= rango) {
                int valor = puntos[i].obtenerValor();
                System.out.println("Punto recolectado: +" + valor);
            }
        }
    }
}

public String descripcion() {
    return "Tipo: " + tipo + " | Rango: " + rango;
}
